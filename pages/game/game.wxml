<!--pages/game/game.wxml-->
<!--
  布局层次（从下到上）：
    1. .stage        ：全屏黑底 / flooding 时变成赢家色（通过 data 绑定）
    2. canvas#stage  ：负责画所有手指圆、呼吸动画、结算强调、铺屏分区等
    3. .hud          ：顶部提示 + 底部赢家数控制栏；flash=true 时底栏加上快速闪烁类
  触摸事件全挂在 .stage 层上，冒泡到 page 级别；控件区（.hud-bottom）用 catch 吃掉触摸不生成圆。
-->
<view
  class="stage {{flooding ? 'stage-flooding' : ''}}"
  style="{{flooding ? 'background-color:' + floodColor : ''}}"
  bindtouchstart="onTouchStart"
  bindtouchmove="onTouchMove"
  bindtouchend="onTouchEnd"
  bindtouchcancel="onTouchCancel"
>
  <canvas
    id="stage"
    type="2d"
    class="stage-canvas"
    disable-scroll="true"
  ></canvas>

  <!-- HUD：顶部提示。文案/情绪由 _computeHint 统一计算，通过 hintMood class 切换样式 -->
  <view class="hud hud-top" catchtouchstart="noop">
    <view class="hint hint-{{hintMood}}">{{hintText}}</view>
  </view>

  <!-- HUD：底部赢家数控制栏（flooding 时隐藏，避免挡住胜利画面）
       ⚠️ 注意：这一层不挂 catchtouchstart，也不响应触摸（wxss 里 pointer-events:none），
       事件拦截收敛到内部两个"真正要交互的控件"上。否则全宽 bar 会把 stage 的触摸吃掉。 -->
  <view class="hud hud-bottom {{flashing ? 'hud-flashing' : ''}}" wx:if="{{!flooding}}">
    <view class="winner-ctrl" catchtouchstart="noop">
      <view
        class="btn {{winnerCount <= 1 ? 'btn-disabled' : ''}}"
        bindtap="onDecWinner"
        catchtouchstart="onDecTouch"
      >−</view>
      <view class="winner-label">
        <text class="winner-num">{{winnerCount}}</text>
        <text class="winner-text"> 位赢家</text>
      </view>
      <view
        class="btn"
        bindtap="onIncWinner"
        catchtouchstart="onIncTouch"
      >+</view>
    </view>

    <!-- 音效主题切换：胶囊小按钮，点一下循环切下一套并立刻试播一次 tap 音 -->
    <view
      class="scheme-btn"
      bindtap="onSchemeTap"
      catchtouchstart="onSchemeTouch"
    >
      <text class="scheme-icon">{{audioSchemeIcon}}</text>
      <text class="scheme-label">{{audioSchemeLabel}}</text>
    </view>
  </view>
</view>
