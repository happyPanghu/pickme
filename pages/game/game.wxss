.stage {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  background: #000000;
  overflow: hidden;
  transition: background-color 450ms ease-out;
}

.game-canvas {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.tip {
  position: absolute;
  top: 80rpx;
  left: 0;
  right: 0;
  text-align: center;
  color: rgba(255, 255, 255, 0.55);
  font-size: 30rpx;
  letter-spacing: 2rpx;
  pointer-events: none;
  font-weight: 300;
}

.tip-hidden {
  opacity: 0;
}

.control-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
  transition: opacity 300ms ease;
}

.control-hidden {
  opacity: 0;
  pointer-events: none;
}

.control-label {
  color: rgba(255, 255, 255, 0.5);
  font-size: 26rpx;
  margin-bottom: 20rpx;
  letter-spacing: 4rpx;
}

.control-group {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 80rpx;
  padding: 12rpx 24rpx;
  backdrop-filter: blur(12rpx);
}

.ctrl-btn {
  width: 80rpx;
  height: 80rpx;
  line-height: 76rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 48rpx;
  text-align: center;
  font-weight: 300;
  transition: transform 120ms ease, background 200ms ease;
}

.ctrl-btn:active {
  transform: scale(0.92);
  background: rgba(255, 255, 255, 0.3);
}

.ctrl-btn.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.ctrl-num {
  min-width: 80rpx;
  margin: 0 24rpx;
  color: #ffffff;
  font-size: 44rpx;
  text-align: center;
  font-weight: 500;
}

.restart-hint {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 120rpx;
  z-index: 20;
}

.restart-hint text {
  color: rgba(255, 255, 255, 0.85);
  font-size: 32rpx;
  letter-spacing: 4rpx;
  padding: 18rpx 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 60rpx;
  backdrop-filter: blur(8rpx);
}
